root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts}]
indent_size = 4
# Allow Composable functions to use PascalCase (standard Compose naming convention)
ktlint_function_naming_ignore_when_annotated_with = Composable
